{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eurogas Nexus",
  "version": "0.5.0",
  "identifier": "com.eurogasnexus.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../web run dev -- --host 127.0.0.1 --port 3000 --strictPort",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm --prefix ../web run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Eurogas Nexus",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "decorations": false,
        "fullscreen": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Eurogas Nexus Loading",
        "width": 520,
        "height": 300,
        "center": true,
        "resizable": false,
        "decorations": false,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* https:; img-src 'self' data: blob: https://tile.openstreetmap.org; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb"],
    "publisher": "Eurogas Nexus",
    "category": "Business",
    "shortDescription": "European gas market intelligence workspace",
    "longDescription": "Eurogas Nexus packages the shared Web workspace as a desktop client. Runtime data is accessed only through the configured backend /api API.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
